{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build STM32 Project",
      "type": "shell",
      // 核心修改：将 cmake 替换为 cube-cmake，调用 ST 现成的工具链
      "command": "cube-cmake --build ${workspaceFolder}/build/Debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      // 保持 GCC 错误解析器开启
      "problemMatcher": "$gcc",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "flash-cmsis-dap",
      "type": "shell",
      "command": "D:/vscode_tools/openocd/bin/openocd.exe",
      "args": [
        "-s",
        "D:/vscode_tools/openocd/share/openocd/scripts",
        "-f",
        "interface/cmsis-dap.cfg",
        "-f",
        "target/stm32f4x.cfg",
        "-c",
        "program build/Debug/ETHERCAT_SLAVE_STD.elf verify reset exit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "dependsOn": "Build STM32 Project"
    }
  ]
}